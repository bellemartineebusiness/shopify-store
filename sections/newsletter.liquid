<div class="newsletter full-width">
  <div class="newsletter__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="newsletter__description">{{ section.settings.description | escape }}</p>
    {%- endif -%}

    {%- form 'customer' -%}
      {%- if form.posted_successfully? -%}
        <p class="newsletter__success" role="status">{{ 'newsletter.success' | t }}</p>
      {%- else -%}
        <input type="hidden" name="contact[tags]" value="newsletter,accepts-marketing">
        <div class="newsletter__form-row">
          <label for="newsletter-email" class="visually-hidden">
            {{ 'newsletter.email_placeholder' | t }}
          </label>
          <input
            id="newsletter-email"
            type="email"
            name="contact[email]"
            class="newsletter__input"
            placeholder="{{ 'newsletter.email_placeholder' | t }}"
            required
            autocomplete="email"
          >
          <button type="submit" class="newsletter__submit">
            {{ 'newsletter.subscribe' | t }}
          </button>
        </div>
        {%- if form.errors -%}
          <p class="newsletter__error" role="alert">{{ 'newsletter.error' | t }}</p>
        {%- endif -%}
        {%- if shop.privacy_policy != blank -%}
          <p class="newsletter__gdpr-notice">
            {{ 'newsletter.gdpr_notice_html' | t: privacy_url: shop.privacy_policy.url }}
          </p>
        {%- else -%}
          <p class="newsletter__gdpr-notice">
            {{ 'newsletter.gdpr_notice_simple' | t }}
          </p>
        {%- endif -%}
      {%- endif -%}
    {%- endform -%}
  </div>
</div>

{% stylesheet %}
  .newsletter {
    background-color: #111;
    color: #fff;
    padding: 5rem 0;
  }

  .newsletter__inner {
    text-align: center;
    padding: 0 1.5rem;
  }

  .newsletter__heading {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .newsletter__description {
    font-size: 0.9rem;
    line-height: 1.7;
    opacity: 0.65;
    max-width: 38rem;
    margin-inline: auto;
    margin-bottom: 2.5rem;
  }

  .newsletter__form-row {
    display: flex;
    max-width: 30rem;
    margin-inline: auto;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .newsletter__input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 0.9rem 1.25rem;
    color: #fff;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    border-radius: 0;
  }

  .newsletter__input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }

  .newsletter__submit {
    background: #fff;
    color: #111;
    border: none;
    padding: 0.9rem 1.75rem;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
    border-radius: 0;
  }

  .newsletter__submit:hover,
  .newsletter__submit:focus-visible {
    background-color: rgba(255, 255, 255, 0.85);
  }

  .newsletter__success {
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    opacity: 0.8;
    max-width: 30rem;
    margin-inline: auto;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .newsletter__error {
    font-size: 0.75rem;
    color: #f08080;
    margin-top: 0.75rem;
    text-align: center;
  }

  .newsletter__gdpr-notice {
    font-size: 0.65rem;
    opacity: 0.4;
    margin-top: 1.25rem;
    max-width: 30rem;
    margin-inline: auto;
    line-height: 1.6;
  }

  .newsletter__gdpr-notice a {
    color: inherit;
    text-underline-offset: 2px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 479px) {
    .newsletter__form-row {
      flex-direction: column;
    }

    .newsletter__submit {
      padding: 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Stay in touch"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:labels.description",
      "default": "Sign up for early access to new collections and exclusive offers."
    }
  ],
  "presets": [
    {
      "name": "t:general.newsletter"
    }
  ]
}
{% endschema %}
