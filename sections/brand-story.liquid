<div class="brand-story full-width">
  <div
    class="brand-story__inner {{ section.settings.image_position }}"
  >
    <div class="brand-story__media">
      {%- if section.settings.image -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            class: 'brand-story__image',
            widths: '400, 600, 800, 1000, 1200',
            sizes: '(min-width: 990px) 50vw, 100vw'
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'brand-story__placeholder' }}
      {%- endif -%}
    </div>

    <div class="brand-story__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="brand-story__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="brand-story__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="brand-story__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_url | default: routes.root_url }}"
          class="brand-story__cta"
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .brand-story {
    background-color: #f9f7f4;
  }

  .brand-story__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
  }

  .brand-story__inner.brand-story--image-right {
    direction: rtl;
  }

  .brand-story__inner.brand-story--image-right > * {
    direction: ltr;
  }

  .brand-story__media {
    overflow: hidden;
    background-color: #e8e4df;
  }

  .brand-story__image,
  .brand-story__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-story__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 4rem;
  }

  .brand-story__eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    opacity: 0.45;
    margin-bottom: 1.25rem;
  }

  .brand-story__heading {
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 300;
    letter-spacing: 0.06em;
    line-height: 1.2;
    margin-bottom: 1.75rem;
  }

  .brand-story__text {
    font-size: 0.95rem;
    line-height: 1.85;
    opacity: 0.75;
    margin-bottom: 2.5rem;
    max-width: 40ch;
  }

  .brand-story__cta {
    display: inline-block;
    width: fit-content;
    padding: 0.85rem 2.5rem;
    border: 1px solid var(--color-foreground);
    text-decoration: none;
    color: inherit;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    transition: background-color 0.25s ease, color 0.25s ease;
  }

  .brand-story__cta:hover,
  .brand-story__cta:focus-visible {
    background-color: var(--color-foreground);
    color: var(--color-background);
  }

  @media (max-width: 749px) {
    .brand-story__inner,
    .brand-story__inner.brand-story--image-right {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .brand-story__media {
      min-height: 55vw;
    }

    .brand-story__content {
      padding: 3rem 1.5rem;
    }

    .brand-story__text {
      max-width: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.brand_story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.subtitle",
      "default": "Our story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Crafted with intention"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:labels.content",
      "default": "<p>Belle Martineé was born from a love of understated elegance. Every piece is thoughtfully designed to move with you through life — from the morning coffee to the evening gathering.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "About us"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:labels.image_position",
      "options": [
        { "value": "brand-story--image-left", "label": "t:options.image_position.left" },
        { "value": "brand-story--image-right", "label": "t:options.image_position.right" }
      ],
      "default": "brand-story--image-left"
    }
  ],
  "presets": [
    {
      "name": "t:general.brand_story"
    }
  ]
}
{% endschema %}
