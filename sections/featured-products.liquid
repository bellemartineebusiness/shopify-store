{%- assign featured_collection = section.settings.collection -%}
{%- assign products_count = section.settings.products_count | default: 4 -%}

<div class="featured-products">
  <div class="featured-products__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="featured-products__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="featured-products__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
  </div>

  {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
    <ul class="featured-products__grid" role="list">
      {%- for product in featured_collection.products limit: products_count -%}
        <li class="product-card">
          <a href="{{ product.url }}" class="product-card__link">
            <div class="product-card__media">
              {%- if product.featured_image -%}
                {{
                  product.featured_image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    class: 'product-card__image',
                    widths: '300, 400, 500, 600, 800',
                    sizes: '(min-width: 990px) calc(25% - 1.5rem), (min-width: 750px) calc(50% - 1rem), calc(100% - 2rem)'
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder' }}
              {%- endif -%}
              {%- if product.compare_at_price > product.price -%}
                <span class="product-card__badge">{{ 'featured_products.sale' | t }}</span>
              {%- endif -%}
            </div>
            <div class="product-card__info">
              <p class="product-card__vendor">{{ product.vendor }}</p>
              <h3 class="product-card__title">{{ product.title }}</h3>
              <p class="product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <s class="product-card__compare-price">{{ product.compare_at_price | money }}</s>
                {%- endif -%}
                <span>{{ product.price | money }}</span>
              </p>
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>

    {%- if section.settings.show_view_all and featured_collection.products_count > products_count -%}
      <div class="featured-products__cta">
        <a href="{{ featured_collection.url }}" class="featured-products__view-all">
          {{ 'featured_products.view_all' | t }}
        </a>
      </div>
    {%- endif -%}
  {%- else -%}
    <p class="featured-products__empty">{{ 'featured_products.no_products' | t }}</p>
  {%- endif -%}
</div>

{% stylesheet %}
  .featured-products {
    padding: 5rem 0;
  }

  .featured-products__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .featured-products__heading {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .featured-products__subheading {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    opacity: 0.6;
    line-height: 1.6;
  }

  .featured-products__grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 989px) {
    .featured-products__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 479px) {
    .featured-products__grid {
      grid-template-columns: 1fr;
    }
  }

  .product-card {
    display: flex;
    flex-direction: column;
  }

  .product-card__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .product-card__media {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: #f5f5f5;
    margin-bottom: 1.25rem;
  }

  .product-card__image,
  .product-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .product-card__link:hover .product-card__image {
    transform: scale(1.03);
  }

  .product-card__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background-color: #111;
    color: #fff;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.6rem;
  }

  .product-card__info {
    padding: 0 0.25rem;
  }

  .product-card__vendor {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.45;
    margin-bottom: 0.4rem;
  }

  .product-card__title {
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .product-card__price {
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }

  .product-card__compare-price {
    opacity: 0.4;
    font-size: 0.75rem;
  }

  .featured-products__cta {
    text-align: center;
    margin-top: 3rem;
  }

  .featured-products__view-all {
    display: inline-block;
    padding: 0.85rem 3rem;
    border: 1px solid var(--color-foreground);
    text-decoration: none;
    color: inherit;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    transition: background-color 0.25s ease, color 0.25s ease;
  }

  .featured-products__view-all:hover,
  .featured-products__view-all:focus-visible {
    background-color: var(--color-foreground);
    color: var(--color-background);
  }

  .featured-products__empty {
    text-align: center;
    opacity: 0.5;
    font-style: italic;
    padding: 2rem 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.featured_products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subtitle"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "t:labels.products_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:labels.show_view_all",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:general.featured_products"
    }
  ]
}
{% endschema %}
